{
  "name": "axhandle",
  "version": "0.2.0",
  "description": "A TypeScript and Vitest harness for iOS Simulator automation through AXe.",
  "keywords": [
    "axe",
    "ios",
    "ios-simulator",
    "e2e",
    "testing",
    "vitest",
    "accessibility",
    "automation"
  ],
  "author": "Alex Hall <me@jalexhall.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alex-hall/AXhandle.git"
  },
  "homepage": "https://github.com/alex-hall/AXhandle#readme",
  "bugs": {
    "url": "https://github.com/alex-hall/AXhandle/issues"
  },
  "license": "MIT",
  "type": "module",
  "packageManager": "npm@10.1.0",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./vitest": {
      "types": "./dist/vitest.d.ts",
      "default": "./dist/vitest.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "default": "./dist/testing.js"
    }
  },
  "files": [
    "dist",
    "src",
    "CHANGELOG.md"
  ],
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "build:app": "turbo run build --filter=@axhandle/integration-sample-app",
    "build:react-native-app": "turbo run build --filter=@axhandle/react-native-sample-app",
    "app:install": "turbo run app:install --filter=@axhandle/integration-sample-app",
    "react-native-app:install": "turbo run app:install --filter=@axhandle/react-native-sample-app",
    "react-native-app:pods": "npm --workspace @axhandle/react-native-sample-app run pods",
    "test": "vitest run",
    "test:e2e": "vitest run tests/e2e --maxWorkers=1",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vitest": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "turbo": "^2.10.4",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  }
}
