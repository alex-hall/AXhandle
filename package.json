{
  "name": "axe-typescript",
  "version": "0.0.0",
  "private": true,
  "description": "A TypeScript and Vitest harness for iOS Simulator automation through AXe.",
  "type": "module",
  "packageManager": "npm@10.1.0",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./vitest": {
      "types": "./dist/vitest.d.ts",
      "default": "./dist/vitest.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "default": "./dist/testing.js"
    }
  },
  "files": [
    "dist"
  ],
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:app": "turbo run build --filter=@axe-typescript/integration-sample-app",
    "build:react-native-app": "turbo run build --filter=@axe-typescript/react-native-sample-app",
    "app:install": "turbo run app:install --filter=@axe-typescript/integration-sample-app",
    "react-native-app:install": "turbo run app:install --filter=@axe-typescript/react-native-sample-app",
    "react-native-app:pods": "npm --workspace @axe-typescript/react-native-sample-app run pods",
    "test": "vitest run",
    "test:e2e": "vitest run tests/e2e --maxWorkers=1",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vitest": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "turbo": "^2.10.4",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  }
}
