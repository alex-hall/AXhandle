{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"]
    },
    "app:install": {
      "cache": false,
      "env": ["SIMULATOR_UDID"],
      "dependsOn": ["build"]
    },
    "test:conformance": {
      "cache": false,
      "dependsOn": ["build"]
    }
  }
}
